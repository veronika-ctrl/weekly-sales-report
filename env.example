# Weekly Report Pipeline Configuration
# Copy this file to .env and adjust values as needed

# --- Supabase (backend: sync + read) - same project as frontend ---
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service Role key (secret) – from same project, required for sync-supabase and writes
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Set true to disable all Supabase reads/writes
DISABLE_SUPABASE=true

# Default week to process (ISO format: YYYY-WW)
DEFAULT_WEEK=2025-42

# Root directory for data files
DATA_ROOT=./data

# Path to PDF layout template
TEMPLATE_PATH=./templates/pdf_layout.yaml

# Output root directory
OUTPUT_ROOT=./reports

# Strict mode: stop on validation errors (true/false)
STRICT_MODE=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Chart export format (png, svg)
CHART_FORMAT=png

# PDF page size (A4 landscape: 842x595 points)
PDF_WIDTH=842
PDF_HEIGHT=595

